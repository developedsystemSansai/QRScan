<script>
// ════════════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════════════
let tables  = [];   // [{id, name, seats:[personId|null × 10]}]
let people  = [];   // [{id, name, mission, dept, status:'registered'|'checkin'}]
let nextTId = 1;
let nextPId = 1;
let dragSrc = null; // {type:'pool'|'seat', personId, fromTable?, fromSeat?}
let currentView = 'map';
let confirmCb   = null;

// ════════════════════════════════════════════════════════════
//  DEMO DATA  (ลบ/แก้ได้ตามต้องการ)
// ════════════════════════════════════════════════════════════
function initDemo() {
  const depts = [
    {m:'กลุ่มการพยาบาล',   d:'งานผู้ป่วยนอก'},
    {m:'กลุ่มการพยาบาล',   d:'งานผู้ป่วยใน'},
    {m:'กลุ่มการพยาบาล',   d:'ห้องคลอด'},
    {m:'กลุ่มการพยาบาล',   d:'ICU'},
    {m:'กลุ่มการแพทย์',    d:'อายุรกรรม'},
    {m:'กลุ่มการแพทย์',    d:'ศัลยกรรม'},
    {m:'กลุ่มการแพทย์',    d:'กุมารเวช'},
    {m:'กลุ่มสนับสนุน',    d:'การเงิน'},
    {m:'กลุ่มสนับสนุน',    d:'เวชระเบียน'},
    {m:'กลุ่มอำนวยการ',    d:'HRD'},
  ];
  const names = [
    'สมชาย ใจดี','นภาพร แสงทอง','วิไล มีสุข','ประยุทธ์ ดวงดี','ศิริพร หวานใจ',
    'กนกวรรณ พรมมา','อาทิตย์ สีแดง','มนัส บุญมี','รัตนา ทองดี','ชลิตา เมืองงาม',
    'วรรณี ดีมาก','สุรชัย คงดี','พิมลรัตน์ สุขใจ','ธนพล แก้วมณี','อรุณี จันทร์ดี',
    'สิทธิชัย ผลดี','นิตยา เกษมสุข','วันเพ็ญ สมบูรณ์','ชาตรี มีทรัพย์','ปณิตา ใจงาม',
    'เอกชัย รุ่งเรือง','กัญญา แสนดี','มาโนช ทองสุข','ลัดดา วงษ์งาม','สายชล บุญส่ง',
    'ธิดา ศรีสุข','วิทยา คำดี','ณัฐพล ดีงาม','อภิรดี สุดดี','ปรีชา มีสกุล'
  ];
  names.forEach((name, i) => {
    people.push({
      id: nextPId++, name,
      mission: depts[i % depts.length].m,
      dept: depts[i % depts.length].d,
      status: i < 5 ? 'checkin' : 'registered'
    });
  });

  ['กลุ่มการพยาบาล','กลุ่มการแพทย์','กลุ่มสนับสนุน','กลุ่มอำนวยการ'].forEach(name => {
    tables.push({id: nextTId++, name, seats: Array(10).fill(null)});
  });

  // Pre-assign first 20
  for (let i = 0;  i < 10; i++) tables[0].seats[i]    = people[i].id;
  for (let i = 10; i < 20; i++) tables[1].seats[i-10] = people[i].id;
}

// ════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════
function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function getPerson(id) { return people.find(p => p.id === id); }
function findSeat(personId) {
  for (const t of tables) {
    const i = t.seats.indexOf(personId);
    if (i !== -1) return {table: t, seatIdx: i};
  }
  return null;
}
function seatedSet() {
  const s = new Set();
  tables.forEach(t => t.seats.forEach(pid => { if (pid) s.add(pid); }));
  return s;
}
function abbr(name) {
  // 2-char Thai abbreviation
  const words = String(name||'').trim().split(/\s+/);
  if (words.length >= 2) return (words[0][0]||'') + (words[1][0]||'');
  return (words[0]||'').substring(0,2);
}

// ════════════════════════════════════════════════════════════
//  RENDER
// ════════════════════════════════════════════════════════════
function render() {
  updateStats();
  renderPool();
  if (currentView === 'map') renderMap();
  else renderList();
}

function updateStats() {
  const seated = seatedSet().size;
  document.getElementById('st-total').textContent      = people.length;
  document.getElementById('st-seated').textContent     = seated;
  document.getElementById('st-unassigned').textContent = people.length - seated;
  document.getElementById('st-tables').textContent     = tables.length;
  document.getElementById('pool-count').textContent    = people.length - seated;
}

// ── MAP VIEW ─────────────────────────────────────────────
function renderMap() {
  const grid = document.getElementById('tables-grid');
  if (tables.length === 0) {
    grid.innerHTML = `
      <div class="empty-state">
        <div class="es-icon">🪑</div>
        <div class="es-title">ยังไม่มีโต๊ะ</div>
        <div class="es-sub">กดปุ่ม "เพิ่มโต๊ะ" เพื่อเริ่มจัดที่นั่ง</div>
        <button class="btn-primary" style="width:auto;padding:10px 24px" onclick="addTable()">➕ เพิ่มโต๊ะแรก</button>
      </div>`;
    return;
  }

  let html = '';
  for (let r = 0; r < tables.length; r += 3) {
    html += '<div class="table-row">';
    for (let c = r; c < Math.min(r+3, tables.length); c++) {
      html += buildTableCardHTML(tables[c]);
    }
    if (r + 3 >= tables.length) {
      html += `<div class="add-table-zone" onclick="addTable()">
        <div class="add-table-plus">＋</div>
        <div>เพิ่มโต๊ะ</div>
      </div>`;
    }
    html += '</div>';
  }
  grid.innerHTML = html;
  bindTableEvents();
}

function buildTableCardHTML(t) {
  const occupied = t.seats.filter(Boolean).length;
  const full = occupied >= 10;
  const seatsHtml = t.seats.map((pid, si) => {
    if (pid) {
      const p = getPerson(pid);
      const cls = p && p.status === 'checkin' ? 'checkin' : 'occupied';
      const ab  = p ? abbr(p.name) : '?';
      return `<div class="seat ${cls}" id="seat-${t.id}-${si}"
                   draggable="true" data-pid="${pid}" data-tid="${t.id}" data-si="${si}"
                   title="${esc(p ? p.name : '')}">${esc(ab)}</div>`;
    }
    return `<div class="seat empty" id="seat-${t.id}-${si}"
                 data-tid="${t.id}" data-si="${si}"></div>`;
  }).join('');

  return `<div class="table-card" id="tc-${t.id}" data-tid="${t.id}">
    <div class="table-header">
      <div class="table-name-wrap">
        <span class="table-icon">🪑</span>
        <span class="table-name" id="tname-${t.id}" onclick="startEditName(${t.id})"
              title="${esc(t.name)}">${esc(t.name)}</span>
      </div>
      <span class="table-count ${full?'full':''}">${occupied}/10</span>
      <div class="table-actions">
        <button class="tbl-btn" title="แก้ไขชื่อโต๊ะ" onclick="startEditName(${t.id})">✏️</button>
        <button class="tbl-btn del" title="ลบโต๊ะ" onclick="confirmDeleteTable(${t.id})">🗑️</button>
      </div>
    </div>
    <div class="seats-grid">${seatsHtml}</div>
  </div>`;
}

function bindTableEvents() {
  // Table card: dragover / drop (drop on table = first empty seat)
  tables.forEach(t => {
    const card = document.getElementById('tc-' + t.id);
    if (!card) return;
    card.addEventListener('dragover', e => { e.preventDefault(); card.classList.add('drag-over'); });
    card.addEventListener('dragleave', e => {
      if (!card.contains(e.relatedTarget)) card.classList.remove('drag-over');
    });
    card.addEventListener('drop', e => {
      e.preventDefault(); card.classList.remove('drag-over');
      handleDrop(t.id, null);
    });

    // Seats
    t.seats.forEach((pid, si) => {
      const seatEl = document.getElementById(`seat-${t.id}-${si}`);
      if (!seatEl) return;

      if (pid) {
        seatEl.addEventListener('dragstart', e => {
          dragSrc = {type:'seat', personId: pid, fromTable: t.id, fromSeat: si};
          setTimeout(() => seatEl.classList.add('drag-src'), 0);
          e.dataTransfer.effectAllowed = 'move';
        });
        seatEl.addEventListener('dragend', () => seatEl.classList.remove('drag-src'));
        seatEl.addEventListener('click', e => { e.stopPropagation(); openEditPerson(pid); });
        seatEl.addEventListener('mouseenter', ev => showTooltip(ev, pid));
        seatEl.addEventListener('mouseleave', hideTooltip);
      }

      seatEl.addEventListener('dragover', e => { e.preventDefault(); e.stopPropagation(); seatEl.classList.add('drag-over-seat'); });
      seatEl.addEventListener('dragleave', () => seatEl.classList.remove('drag-over-seat'));
      seatEl.addEventListener('drop', e => {
        e.preventDefault(); e.stopPropagation(); seatEl.classList.remove('drag-over-seat');
        handleDrop(t.id, si);
      });
    });
  });
}

// แทนที่ฟังก์ชัน renderList() เดิม
function renderList() {
  const panel = document.getElementById('panel-list');
  const seated = seatedSet();
  let html = '<div style="display:flex;flex-direction:column;gap:14px">';

  tables.forEach(t => {
    const members = t.seats.filter(Boolean).map(getPerson).filter(Boolean);
    html += `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden">
      <div class="list-section-header">
        <span class="list-section-name">🪑 ${esc(t.name)}</span>
        <span class="list-section-count">${members.length} / 10 คน</span>
      </div>`;
    if (members.length === 0) {
      html += `<div style="text-align:center;padding:16px;color:var(--text-3);font-size:13px">ยังไม่มีสมาชิก — ลากรายชื่อมาวางในผังที่นั่ง</div>`;
    } else {
      html += `<table class="list-table" style="background:var(--surface)">
        <thead><tr><th style="width:32px">#</th><th>ชื่อ-นามสกุล</th><th>กลุ่มภารกิจ / กลุ่มงาน</th><th>สถานะ</th><th>แก้ไข</th></tr></thead><tbody>`;
      members.forEach((p, i) => {
        const badge = p.status === 'checkin' ? '<span class="status-badge checkin">✅ เช็คอิน</span>' : '<span class="status-badge seated">⏳ ลงทะเบียน</span>';
        html += `<tr>
          <td style="color:var(--text-3)">${i+1}</td>
          <td style="font-weight:600">${esc(p.name)}</td>
          <td style="color:var(--text-2)">${esc(p.mission||'')}${p.dept?' · '+esc(p.dept):''}</td>
          <td>${badge}</td>
          <td><button class="btn-sm" style="padding:3px 8px;font-size:11px" onclick="openEditPerson('${p.id}')">✏️</button></td>
        </tr>`;
      });
      html += `</tbody></table>`;
    }
    html += `</div>`;
  });

  const unassigned = people.filter(p => !seated.has(p.id));
  if (unassigned.length > 0) {
    html += `<div style="background:var(--gold-lt);border:1px solid var(--gold);border-radius:var(--radius-lg);overflow:hidden">
      <div class="list-section-header" style="background:var(--gold);border-color:var(--gold)">
        <span class="list-section-name">⚠️ ยังไม่มีที่นั่ง</span>
        <span class="list-section-count">${unassigned.length} คน</span>
      </div>
      <table class="list-table" style="background:var(--gold-lt)"><thead><tr><th>#</th><th>ชื่อ-นามสกุล</th><th>กลุ่มงาน</th><th>สถานะ</th><th>แก้ไข</th></tr></thead><tbody>`;
    unassigned.forEach((p, i) => {
      html += `<tr>
        <td style="color:var(--text-3)">${i+1}</td>
        <td style="font-weight:600">${esc(p.name)}</td>
        <td style="color:var(--text-2)">${esc(p.mission||'')}${p.dept?' · '+esc(p.dept):''}</td>
        <td><span class="status-badge unassign">ยังไม่มีที่นั่ง</span></td>
        <td><button class="btn-sm" style="padding:3px 8px;font-size:11px" onclick="openEditPerson('${p.id}')">✏️</button></td>
      </tr>`;
    });
    html += `</tbody></table></div>`;
  }
  html += '</div>';
  panel.innerHTML = html;
}

// แทนที่ฟังก์ชัน renderPool() เดิม
function renderPool() {
  const q = document.getElementById('pool-search').value.toLowerCase().trim();
  const seated = seatedSet();
  const unassigned = people.filter(p =>
    !seated.has(p.id) && (!q || p.name.toLowerCase().includes(q) || (p.dept||'').toLowerCase().includes(q) || (p.mission||'').toLowerCase().includes(q))
  );
  const list = document.getElementById('pool-list');
  if (unassigned.length === 0) {
    list.innerHTML = `<div class="pool-empty">${q ? '🔍 ไม่พบรายชื่อที่ค้นหา' : '✅ ทุกคนมีที่นั่งแล้ว!'}</div>`;
    return;
  }
  list.innerHTML = unassigned.map(p => `
    <div class="pool-chip" id="pc-${p.id}" draggable="true"
         onclick="openEditPerson('${p.id}')"
         onmouseenter="showTooltip(event,'${p.id}')" onmouseleave="hideTooltip()">
      <div class="pool-chip-dot" style="background:${p.status==='checkin'?'var(--green)':'var(--gold)'}"></div>
      <div style="flex:1;min-width:0">
        <div class="pool-chip-name">${esc(p.name)}</div>
        <div class="pool-chip-dept">${esc(p.mission||'')}${p.dept?' · '+esc(p.dept):''}</div>
      </div>
      <span style="font-size:11px;color:var(--text-3)">${p.status==='checkin'?'✅':''}</span>
    </div>
  `).join('');
  unassigned.forEach(p => {
    const el = document.getElementById('pc-'+p.id);
    if (!el) return;
    el.addEventListener('dragstart', e => {
      dragSrc = {type:'pool', personId: p.id};
      setTimeout(() => el.classList.add('dragging-src'), 0);
      e.dataTransfer.effectAllowed = 'move';
    });
    el.addEventListener('dragend', () => el.classList.remove('dragging-src'));
  });
}

function filterPool() { renderPool(); }

// ════════════════════════════════════════════════════════════
//  DRAG & DROP HANDLER
// ════════════════════════════════════════════════════════════
function handleDrop(targetTableId, targetSeatIdx) {
  if (!dragSrc) return;
  const targetTable = tables.find(t => t.id === targetTableId);
  if (!targetTable) { dragSrc = null; return; }

  if (targetSeatIdx !== null && targetSeatIdx !== undefined) {
    // Dropped on a specific seat
    const existingPid = targetTable.seats[targetSeatIdx];

    if (dragSrc.type === 'pool') {
      if (existingPid) { toast('ที่นั่งนี้มีผู้นั่งแล้ว', 'err'); dragSrc = null; return; }
      targetTable.seats[targetSeatIdx] = dragSrc.personId;
      toast(`✅ จัดที่นั่ง: ${getPerson(dragSrc.personId)?.name}`, 'ok');

    } else if (dragSrc.type === 'seat') {
      const fromTable = tables.find(t => t.id === dragSrc.fromTable);
      if (existingPid) {
        // Swap seats
        if (fromTable) fromTable.seats[dragSrc.fromSeat] = existingPid;
        targetTable.seats[targetSeatIdx] = dragSrc.personId;
        toast('🔄 สลับที่นั่งเรียบร้อย', 'info');
      } else {
        if (fromTable) fromTable.seats[dragSrc.fromSeat] = null;
        targetTable.seats[targetSeatIdx] = dragSrc.personId;
        toast(`✅ ย้ายที่นั่ง: ${getPerson(dragSrc.personId)?.name}`, 'ok');
      }
    }
  } else {
    // Dropped on table card → first empty seat
    const emptyIdx = targetTable.seats.indexOf(null);
    if (emptyIdx === -1) { toast(`❌ โต๊ะ "${targetTable.name}" เต็มแล้ว`, 'err'); dragSrc = null; return; }

    if (dragSrc.type === 'pool') {
      targetTable.seats[emptyIdx] = dragSrc.personId;
      toast(`✅ จัดที่นั่ง: ${getPerson(dragSrc.personId)?.name} → ${targetTable.name}`, 'ok');
    } else {
      const fromTable = tables.find(t => t.id === dragSrc.fromTable);
      if (fromTable) fromTable.seats[dragSrc.fromSeat] = null;
      targetTable.seats[emptyIdx] = dragSrc.personId;
      toast(`✅ ย้าย: ${getPerson(dragSrc.personId)?.name} → ${targetTable.name}`, 'ok');
    }
  }

  dragSrc = null;
  render();
}

// ════════════════════════════════════════════════════════════
//  TABLE MANAGEMENT
// ════════════════════════════════════════════════════════════
function addTable() {
  const name = 'กลุ่มงาน_' + (tables.length + 1);
  tables.push({id: nextTId++, name, seats: Array(10).fill(null)});
  setView('map');
  render();
  toast(`➕ เพิ่มโต๊ะ "${name}" แล้ว`, 'ok');
  setTimeout(() => { document.getElementById('room-canvas').scrollTop = 99999; }, 100);
}

function startEditName(tableId) {
  const nameEl = document.getElementById('tname-' + tableId);
  if (!nameEl) return;
  const t = tables.find(x => x.id === tableId);
  if (!t) return;
  const input = document.createElement('input');
  input.className = 'table-name-input';
  input.value = t.name;
  nameEl.replaceWith(input);
  input.focus(); input.select();
  const save = () => {
    const val = input.value.trim() || t.name;
    t.name = val;
    render();
    toast(`✏️ เปลี่ยนชื่อโต๊ะเป็น "${val}" แล้ว`, 'ok');
  };
  input.addEventListener('blur', save);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter') { input.blur(); }
    if (e.key === 'Escape') { input.value = t.name; input.blur(); }
  });
}

function confirmDeleteTable(tableId) {
  const t = tables.find(x => x.id === tableId);
  if (!t) return;
  const occupied = t.seats.filter(Boolean).length;
  confirm2(
    '🗑️ ลบโต๊ะ',
    `ต้องการลบโต๊ะ "${t.name}"?${occupied ? `\n\nผู้นั่ง ${occupied} คน จะถูกย้ายกลับมายังรายชื่อที่ยังไม่มีที่นั่ง` : ''}`,
    () => {
      tables = tables.filter(x => x.id !== tableId);
      render();
      toast(`🗑️ ลบโต๊ะ "${t.name}" แล้ว`, 'ok');
    }
  );
}

function clearAllSeats() {
  confirm2('🗑️ ล้างที่นั่งทั้งหมด', 'ต้องการย้ายทุกคนออกจากที่นั่งทั้งหมด?', () => {
    tables.forEach(t => t.seats = Array(10).fill(null));
    render();
    toast('ล้างที่นั่งทั้งหมดแล้ว', 'ok');
  });
}

function autoAssign() {
  const seated = seatedSet();
  const unassigned = people.filter(p => !seated.has(p.id));
  if (unassigned.length === 0) { toast('✅ ทุกคนมีที่นั่งแล้ว', 'ok'); return; }
  let assigned = 0;
  for (const p of unassigned) {
    let placed = false;
    for (const t of tables) {
      const empty = t.seats.indexOf(null);
      if (empty !== -1) { t.seats[empty] = p.id; placed = true; assigned++; break; }
    }
    if (!placed) break;
  }
  render();
  toast(`⚡ จัดที่นั่งอัตโนมัติ ${assigned} คน`, 'ok');
  if (assigned < unassigned.length) {
    toast(`⚠️ ที่นั่งเต็ม ยังเหลืออีก ${unassigned.length - assigned} คน`, 'err');
  }
}

// ════════════════════════════════════════════════════════════
//  PERSON MANAGEMENT
// ════════════════════════════════════════════════════════════
function openAddPerson() {
  document.getElementById('mp-name').value    = '';
  document.getElementById('mp-mission').value = '';
  document.getElementById('mp-dept').value    = '';
  document.getElementById('mp-status').value  = 'registered';
  document.getElementById('mp-edit-id').value = '';
  document.getElementById('mp-del-btn').style.display = 'none';
  document.getElementById('mperson-title').textContent = '➕ เพิ่มรายชื่อ';
  openModal('modal-person');
}

function openEditPerson(personId) {
  const p = getPerson(personId);
  if (!p) return;
  document.getElementById('mp-name').value    = p.name;
  document.getElementById('mp-mission').value = p.mission || '';
  document.getElementById('mp-dept').value    = p.dept || '';
  document.getElementById('mp-status').value  = p.status || 'registered';
  document.getElementById('mp-edit-id').value = personId;
  document.getElementById('mp-del-btn').style.display = '';
  document.getElementById('mperson-title').textContent = '✏️ แก้ไขรายชื่อ';
  openModal('modal-person');
}

function savePerson() {
  const name = document.getElementById('mp-name').value.trim();
  if (!name) { document.getElementById('mp-name').focus(); toast('กรุณากรอกชื่อ', 'err'); return; }
  const mission = document.getElementById('mp-mission').value.trim();
  const dept    = document.getElementById('mp-dept').value.trim();
  const status  = document.getElementById('mp-status').value;
  const editId  = parseInt(document.getElementById('mp-edit-id').value);

  if (editId) {
    const p = getPerson(editId);
    if (p) { p.name = name; p.mission = mission; p.dept = dept; p.status = status; }
    toast(`✏️ แก้ไข "${name}" แล้ว`, 'ok');
  } else {
    people.push({id: nextPId++, name, mission, dept, status});
    toast(`➕ เพิ่ม "${name}" แล้ว`, 'ok');
  }
  closeModal('modal-person');
  render();
}

function deletePerson() {
  const editId = parseInt(document.getElementById('mp-edit-id').value);
  const p = getPerson(editId);
  if (!p) return;
  confirm2('ลบรายชื่อ', `ต้องการลบ "${p.name}" ออกจากระบบทั้งหมด?`, () => {
    people = people.filter(x => x.id !== editId);
    tables.forEach(t => { t.seats = t.seats.map(s => s === editId ? null : s); });
    closeModal('modal-person');
    render();
    toast(`🗑️ ลบ "${p.name}" แล้ว`, 'ok');
  });
}

// ════════════════════════════════════════════════════════════
//  VIEWS
// ════════════════════════════════════════════════════════════
function setView(v) {
  currentView = v;
  document.getElementById('panel-map').style.display  = v === 'map'  ? '' : 'none';
  document.getElementById('panel-list').style.display = v === 'list' ? '' : 'none';
  document.getElementById('btn-view-map').classList.toggle('active',  v === 'map');
  document.getElementById('btn-view-list').classList.toggle('active', v === 'list');
  render();
}

// ════════════════════════════════════════════════════════════
//  TOOLTIP
// ════════════════════════════════════════════════════════════
const tipEl = document.getElementById('tooltip');
function showTooltip(e, personId) {
  const p = getPerson(personId);
  if (!p) return;
  const loc = findSeat(personId);
  const tableName = loc ? loc.table.name : 'ยังไม่มีที่นั่ง';
  tipEl.innerHTML = `<b>${esc(p.name)}</b><br>${esc(p.mission || '')}${p.dept ? ' · '+esc(p.dept) : ''}<br>📍 ${esc(tableName)}<br>${p.status === 'checkin' ? '✅ เช็คอินแล้ว' : '⏳ ยังไม่เช็คอิน'}`;
  tipEl.classList.add('show');
  positionTip(e);
}
function hideTooltip() { tipEl.classList.remove('show'); }
document.addEventListener('mousemove', e => { if (tipEl.classList.contains('show')) positionTip(e); });
function positionTip(e) {
  let x = e.clientX + 14, y = e.clientY - 10;
  if (x + 250 > window.innerWidth)  x = e.clientX - 254;
  if (y + 100 > window.innerHeight) y = e.clientY - 110;
  tipEl.style.left = x + 'px'; tipEl.style.top = y + 'px';
}

// ════════════════════════════════════════════════════════════
//  MODALS
// ════════════════════════════════════════════════════════════
function openModal(id) {
  document.getElementById(id).classList.add('open');
  setTimeout(() => {
    const first = document.querySelector(`#${id} input:not([type=hidden]),#${id} select`);
    if (first) first.focus();
  }, 80);
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(el =>
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); })
);
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.modal-overlay.open').forEach(el => el.classList.remove('open'));
});

function confirm2(title, msg, cb) {
  document.getElementById('confirm-title').textContent = title;
  document.getElementById('confirm-msg').textContent   = msg;
  confirmCb = cb;
  openModal('modal-confirm');
}
document.getElementById('confirm-ok-btn').addEventListener('click', () => {
  closeModal('modal-confirm');
  if (confirmCb) { confirmCb(); confirmCb = null; }
});

// ════════════════════════════════════════════════════════════
//  EXPORT / PRINT
// ════════════════════════════════════════════════════════════
function exportLayout() {
  const layout = {
    exportedAt: new Date().toLocaleString('th-TH', {
      year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit'
    }),
    totalPeople: people.length,
    totalTables: tables.length,
    tables: tables.map(t => ({
      name: t.name,
      capacity: 10,
      occupied: t.seats.filter(Boolean).length,
      seats: t.seats.map((pid, i) => {
        const p = getPerson(pid);
        return pid && p ? {seat: i+1, name: p.name, mission: p.mission||'', dept: p.dept||'', status: p.status} : {seat: i+1, name: null};
      })
    })),
    unassigned: people.filter(p => !seatedSet().has(p.id)).map(p => ({name:p.name, mission:p.mission||'', dept:p.dept||'', status:p.status}))
  };
  const blob = new Blob([JSON.stringify(layout, null, 2)], {type:'application/json'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'seat-layout-' + new Date().toISOString().slice(0,10) + '.json'; a.click();
  toast('💾 บันทึกผังที่นั่ง JSON แล้ว', 'ok');
}

function printMap() {
  window.print();
}

// ════════════════════════════════════════════════════════════
//  TOAST
// ════════════════════════════════════════════════════════════
function toast(msg, type='ok') {
  const cls = {ok:'t-ok', err:'t-err', info:'t-info'}[type] || 't-ok';
  const el = document.createElement('div');
  el.className = `toast ${cls}`;
  el.textContent = msg;
  document.getElementById('toast-container').prepend(el);
  setTimeout(() => { el.classList.add('out'); setTimeout(() => el.remove(), 220); }, 3000);
}

