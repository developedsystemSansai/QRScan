<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="theme-color" content="#1a5f7a">
<title>Seat Map – ระบบจัดที่นั่งสัมมนา · โรงพยาบาลสันทราย</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800&family=Noto+Serif+Thai:wght@400;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   DESIGN SYSTEM — Warm Institutional (matches index.html / register.html)
   ═══════════════════════════════════════════════════ */
:root {
  --bg:           #f5f3ef;
  --bg2:          #ede9e2;
  --surface:      #ffffff;
  --surface2:     #faf9f7;
  --surface3:     #f0ede8;
  --border:       #d8d2c8;
  --border2:      #c4bcb0;

  --primary:      #1a5f7a;
  --primary-dk:   #134a5f;
  --primary-lt:   #e8f4f8;
  --primary-glow: rgba(26,95,122,.14);

  --gold:         #c9882a;
  --gold-lt:      #fdf3e3;
  --gold-glow:    rgba(201,136,42,.18);

  --green:        #1a7a5e;
  --green-lt:     #e6f4f0;
  --green-glow:   rgba(26,122,94,.18);
  --red:          #b83535;
  --red-lt:       #fdf0f0;
  --red-glow:     rgba(184,53,53,.14);
  --amber:        #b06820;
  --amber-lt:     #fef4e8;

  --text:         #2c2824;
  --text-2:       #5c5650;
  --text-3:       #9a918a;

  --serif:        'Noto Serif Thai', 'Tahoma', serif;
  --sans:         'Noto Sans Thai', 'Tahoma', sans-serif;
  --mono:         'IBM Plex Mono', monospace;

  --radius-sm:    8px;
  --radius:       10px;
  --radius-lg:    16px;
  --radius-xl:    20px;
  --shadow-sm:    0 1px 4px rgba(0,0,0,.06), 0 2px 8px rgba(0,0,0,.04);
  --shadow:       0 2px 8px rgba(0,0,0,.07), 0 6px 24px rgba(0,0,0,.05);
  --shadow-lg:    0 4px 16px rgba(0,0,0,.08), 0 12px 40px rgba(0,0,0,.07);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  background-image:
    radial-gradient(ellipse 80% 60% at 10% 0%, rgba(26,95,122,.05) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 90% 100%, rgba(201,136,42,.04) 0%, transparent 50%);
}

::-webkit-scrollbar { width:5px; }
::-webkit-scrollbar-track { background:var(--bg2); }
::-webkit-scrollbar-thumb { background:var(--border2); border-radius:5px; }

/* ═══════════════════════════════════════════════════
   TOP BAR
   ═══════════════════════════════════════════════════ */
.top-bar {
  position: sticky; top: 0; z-index: 200;
  background: rgba(26,95,122,.97);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 3px solid var(--gold);
  box-shadow: 0 2px 16px rgba(0,0,0,.18);
}
.top-bar-inner {
  max-width: 1400px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 16px; gap: 10px; flex-wrap: wrap;
}
.brand { display:flex; align-items:center; gap:10px; }
.brand-seal {
  width:36px; height:36px; border-radius:50%; flex-shrink:0;
  background: linear-gradient(145deg, var(--gold), #e8a838);
  display:flex; align-items:center; justify-content:center;
  font-size:18px; box-shadow: 0 0 0 2px rgba(255,255,255,.2), 0 2px 8px rgba(0,0,0,.3);
}
.brand-name { font-family:var(--serif); font-size:13px; font-weight:700; color:#fff; line-height:1.2; }
.brand-sub  { font-size:10px; color:rgba(255,255,255,.65); }
.top-actions { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.btn-top {
  display:flex; align-items:center; gap:6px;
  padding:6px 12px; border-radius:var(--radius);
  background:rgba(255,255,255,.12); color:rgba(255,255,255,.9);
  font-family:var(--sans); font-size:12px; font-weight:600;
  border:1px solid rgba(255,255,255,.2); cursor:pointer; transition:all .2s; white-space:nowrap;
}
.btn-top:hover { background:rgba(255,255,255,.22); color:#fff; }
.btn-top.gold  { background:var(--gold); border-color:var(--gold); color:#fff; }
.btn-top.gold:hover { background:#b8791f; }
.btn-top.green { background:var(--green); border-color:var(--green); color:#fff; }
.btn-top.green:hover { background:#146147; }

/* ═══════════════════════════════════════════════════
   LAYOUT
   ═══════════════════════════════════════════════════ */
.main-wrap {
  max-width:1400px; margin:0 auto; padding:16px;
  display:grid; grid-template-columns:290px 1fr; gap:16px;
  min-height:calc(100vh - 62px);
}
@media(max-width:960px){
  .main-wrap { grid-template-columns:1fr; }
  .sidebar { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
}
@media(max-width:600px){
  .sidebar { grid-template-columns:1fr; }
}

/* ═══════════════════════════════════════════════════
   SIDEBAR
   ═══════════════════════════════════════════════════ */
.sidebar { display:flex; flex-direction:column; gap:12px; }
.side-card {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius-lg); padding:16px; box-shadow:var(--shadow-sm);
}
.side-title {
  font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
  color:var(--primary); border-left:3px solid var(--primary); padding-left:8px;
  margin-bottom:12px;
}

/* Stats */
.stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.stat-box  { background:var(--bg2); border-radius:var(--radius); padding:10px; text-align:center; }
.stat-num  { font-size:24px; font-weight:700; color:var(--primary); line-height:1; }
.stat-lbl  { font-size:10px; color:var(--text-3); margin-top:3px; }
.stat-box.green .stat-num { color:var(--green); }
.stat-box.gold  .stat-num { color:var(--gold); }
.stat-box.red   .stat-num { color:var(--red); }

/* Legend */
.legend { display:flex; flex-direction:column; gap:7px; }
.legend-row { display:flex; align-items:center; gap:8px; font-size:12px; color:var(--text-2); }
.ldot { width:14px; height:14px; border-radius:4px; flex-shrink:0; }
.ldot.empty   { background:var(--surface2); border:1.5px dashed var(--border2); }
.ldot.seated  { background:#dbeafe; border:1.5px solid #93c5fd; }
.ldot.checkin { background:var(--green-lt); border:1.5px solid #6ee7b7; }
.ldot.pool    { background:var(--gold-lt); border:1.5px solid var(--gold); }

/* Pool */
.pool-search {
  width:100%; padding:8px 10px;
  border:1px solid var(--border); border-radius:var(--radius);
  font-family:var(--sans); font-size:13px; color:var(--text);
  background:var(--surface2); outline:none; margin-bottom:8px; transition:border .2s;
}
.pool-search:focus { border-color:var(--primary); box-shadow:0 0 0 3px var(--primary-glow); }
.pool-list { max-height:300px; overflow-y:auto; display:flex; flex-direction:column; gap:4px; }
.pool-chip {
  display:flex; align-items:center; gap:8px;
  padding:7px 10px; background:var(--surface2);
  border:1px solid var(--border); border-radius:var(--radius);
  cursor:grab; transition:all .18s; user-select:none;
}
.pool-chip:hover    { background:var(--primary-lt); border-color:rgba(26,95,122,.35); transform:translateX(2px); }
.pool-chip.dragging-src { opacity:.35; transform:scale(.95); }
.pool-chip-dot   { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
.pool-chip-name  { font-size:12.5px; font-weight:600; color:var(--text); flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.pool-chip-dept  { font-size:10px; color:var(--text-3); overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.pool-empty      { text-align:center; color:var(--text-3); font-size:12px; padding:20px 0; }

/* ═══════════════════════════════════════════════════
   CANVAS AREA
   ═══════════════════════════════════════════════════ */
.canvas-wrap { display:flex; flex-direction:column; gap:12px; }
.canvas-toolbar {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius-lg); padding:11px 16px;
  display:flex; align-items:center; gap:9px; flex-wrap:wrap;
  box-shadow:var(--shadow-sm);
}
.tb-label { font-size:12px; color:var(--text-2); font-weight:600; }
.btn-sm {
  display:flex; align-items:center; gap:5px;
  padding:6px 12px; border-radius:var(--radius-sm);
  font-family:var(--sans); font-size:12px; font-weight:600;
  border:1.5px solid var(--border2); background:var(--surface);
  color:var(--text-2); cursor:pointer; transition:all .18s; white-space:nowrap;
}
.btn-sm:hover  { background:var(--primary-lt); border-color:var(--primary); color:var(--primary); }
.btn-sm.active { background:var(--primary); color:#fff; border-color:var(--primary); }
.btn-sm.danger:hover { background:var(--red-lt); border-color:var(--red); color:var(--red); }
.tb-sep { width:1px; height:24px; background:var(--border); flex-shrink:0; }
.tb-hint { font-size:11.5px; color:var(--text-3); margin-left:auto; }

/* Room canvas */
.room-canvas {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--radius-xl); padding:24px;
  box-shadow:var(--shadow); min-height:520px; overflow:auto;
}
.room-title-bar {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:20px; flex-wrap:wrap; gap:8px;
}
.room-name  { font-family:var(--serif); font-size:16px; font-weight:700; color:var(--primary); }
.room-hint  { font-size:12px; color:var(--text-3); }
.tables-grid { display:flex; flex-direction:column; gap:20px; }
.table-row   { display:flex; gap:16px; flex-wrap:wrap; align-items:flex-start; }

/* Table card */
.table-card {
  background:var(--surface2); border:1.5px solid var(--border);
  border-radius:var(--radius-lg); padding:13px;
  min-width:210px; flex:0 0 auto; transition:all .2s; position:relative;
}
.table-card.drag-over {
  border-color:var(--primary); background:var(--primary-lt);
  box-shadow:0 0 0 3px var(--primary-glow);
}
.table-header {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:11px; gap:6px;
}
.table-name-wrap { display:flex; align-items:center; gap:6px; flex:1; min-width:0; }
.table-icon { font-size:14px; flex-shrink:0; }
.table-name {
  font-size:12.5px; font-weight:700; color:var(--primary);
  flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  cursor:pointer; padding:2px 4px; border-radius:4px; transition:background .15s;
}
.table-name:hover { background:var(--primary-lt); }
.table-name-input {
  font-size:12.5px; font-weight:700; color:var(--primary);
  border:1.5px solid var(--primary); border-radius:6px;
  padding:2px 7px; background:var(--primary-lt);
  font-family:var(--sans); outline:none; width:100%;
}
.table-count {
  font-size:10px; color:var(--text-3); background:var(--bg2);
  border-radius:20px; padding:2px 7px; white-space:nowrap; flex-shrink:0;
}
.table-count.full { background:#dcfce7; color:#166534; font-weight:700; }
.table-actions { display:flex; gap:4px; flex-shrink:0; }
.tbl-btn {
  width:23px; height:23px; border-radius:5px; border:1px solid var(--border);
  background:var(--surface); cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; color:var(--text-3); transition:all .15s; flex-shrink:0;
}
.tbl-btn:hover     { background:var(--primary-lt); border-color:var(--primary); color:var(--primary); }
.tbl-btn.del:hover { background:var(--red-lt); border-color:var(--red); color:var(--red); }

/* Seats grid */
.seats-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:5px; }
.seat {
  width:34px; height:34px; border-radius:8px;
  display:flex; align-items:center; justify-content:center;
  font-size:9px; font-weight:700; transition:all .18s;
  position:relative; border:1.5px solid transparent;
  overflow:hidden;
}
.seat.empty   { background:var(--surface); border-style:dashed; border-color:var(--border2); color:var(--text-3); cursor:default; }
.seat.occupied{
  background:#dbeafe; border-color:#93c5fd; color:#1e40af;
  cursor:pointer;
}
.seat.occupied:hover { background:#bfdbfe; transform:scale(1.1); z-index:2; }
.seat.checkin { background:var(--green-lt); border-color:#6ee7b7; color:var(--green); cursor:pointer; }
.seat.checkin:hover  { background:#c6f0e4; transform:scale(1.1); z-index:2; }
.seat[draggable="true"]:hover { cursor:grab; }
.seat.drag-over-seat { background:rgba(26,95,122,.12); border-color:var(--primary); border-style:solid; }
.seat.drag-src       { opacity:.35; transform:scale(.92); }

/* Add table button */
.add-table-zone {
  min-width:210px; min-height:90px;
  border:2px dashed var(--border2); border-radius:var(--radius-lg);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:5px; cursor:pointer; color:var(--text-3); font-size:12px; font-weight:600;
  transition:all .2s; background:var(--surface2);
}
.add-table-zone:hover { border-color:var(--primary); color:var(--primary); background:var(--primary-lt); }
.add-table-plus { font-size:24px; line-height:1; }

/* Empty state */
.empty-state { text-align:center; padding:60px 0; color:var(--text-3); }
.empty-state .es-icon { font-size:48px; margin-bottom:12px; }
.empty-state .es-title { font-size:16px; font-weight:700; color:var(--text-2); margin-bottom:6px; }
.empty-state .es-sub   { font-size:13px; margin-bottom:20px; }

/* ═══════════════════════════════════════════════════
   LIST VIEW
   ═══════════════════════════════════════════════════ */
.list-table {
  width:100%; border-collapse:collapse; font-size:13px;
}
.list-table th {
  text-align:left; padding:8px 10px; font-size:11px; font-weight:700;
  color:var(--text-3); letter-spacing:.04em; text-transform:uppercase;
  border-bottom:1.5px solid var(--border);
}
.list-table td { padding:8px 10px; border-bottom:1px solid var(--border); }
.list-table tr:last-child td { border-bottom:none; }
.list-table tr:hover td { background:var(--surface2); }
.list-section-header {
  background:linear-gradient(135deg, var(--primary) 0%, #1a6d8a 100%);
  color:#fff; padding:10px 16px;
  display:flex; align-items:center; justify-content:space-between;
}
.list-section-name { font-size:13px; font-weight:700; font-family:var(--serif); }
.list-section-count {
  font-size:11px; background:rgba(255,255,255,.2);
  padding:2px 9px; border-radius:20px;
}
.status-badge {
  display:inline-flex; align-items:center; gap:4px;
  font-size:11px; font-weight:600; padding:3px 9px; border-radius:20px;
}
.status-badge.checkin  { background:var(--green-lt); color:var(--green); }
.status-badge.seated   { background:var(--primary-lt); color:var(--primary); }
.status-badge.unassign { background:var(--gold-lt); color:var(--amber); }

/* ═══════════════════════════════════════════════════
   TOOLTIP
   ═══════════════════════════════════════════════════ */
.tooltip {
  position:fixed; background:var(--text); color:#fff;
  padding:8px 13px; border-radius:var(--radius); font-size:12.5px;
  pointer-events:none; z-index:9999; opacity:0; transition:opacity .15s;
  max-width:240px; line-height:1.6; white-space:nowrap;
  box-shadow:var(--shadow-lg);
}
.tooltip.show { opacity:1; }
.tooltip b { font-weight:700; }

/* ═══════════════════════════════════════════════════
   MODAL
   ═══════════════════════════════════════════════════ */
.modal-overlay {
  position:fixed; inset:0; background:rgba(0,0,0,.35);
  z-index:500; display:none; align-items:center; justify-content:center;
  backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px);
}
.modal-overlay.open { display:flex; }
.modal {
  background:var(--surface); border-radius:var(--radius-xl);
  padding:24px 26px; width:360px; box-shadow:var(--shadow-lg);
  max-height:90vh; overflow-y:auto; animation:modalIn .22s ease;
}
@keyframes modalIn { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
.modal-title { font-family:var(--serif); font-size:17px; font-weight:700; color:var(--primary); margin-bottom:18px; }
.modal-field { margin-bottom:14px; }
.modal-label {
  display:block; font-size:11px; font-weight:700;
  color:var(--text-2); text-transform:uppercase; letter-spacing:.06em; margin-bottom:6px;
}
.modal-input {
  width:100%; padding:9px 12px;
  border:1.5px solid var(--border); border-radius:var(--radius);
  font-family:var(--sans); font-size:14px; color:var(--text);
  background:var(--surface2); outline:none; transition:border .2s;
}
.modal-input:focus { border-color:var(--primary); box-shadow:0 0 0 3px var(--primary-glow); }
.modal-btns { display:flex; gap:8px; margin-top:18px; }
.btn-primary {
  flex:1; padding:10px; background:var(--primary); color:#fff;
  border:none; border-radius:var(--radius);
  font-family:var(--sans); font-size:14px; font-weight:600;
  cursor:pointer; transition:background .2s;
}
.btn-primary:hover { background:var(--primary-dk); }
.btn-secondary {
  padding:10px 16px; background:var(--surface2); color:var(--text-2);
  border:1.5px solid var(--border); border-radius:var(--radius);
  font-family:var(--sans); font-size:14px; font-weight:600; cursor:pointer;
}
.btn-secondary:hover { background:var(--bg2); }
.btn-danger {
  padding:10px 14px; background:var(--red-lt); color:var(--red);
  border:1.5px solid var(--red); border-radius:var(--radius);
  font-family:var(--sans); font-size:14px; font-weight:600; cursor:pointer;
}
.btn-danger:hover { background:var(--red); color:#fff; }

/* ═══════════════════════════════════════════════════
   TOAST
   ═══════════════════════════════════════════════════ */
#toast-container {
  position:fixed; bottom:20px; right:20px; z-index:9999;
  display:flex; flex-direction:column; gap:8px; pointer-events:none;
}
.toast {
  display:flex; align-items:center; gap:10px;
  padding:10px 16px; background:var(--surface);
  border:1px solid var(--border); border-radius:var(--radius-lg);
  box-shadow:var(--shadow-lg); font-size:13px; font-weight:600;
  pointer-events:none; animation:toastIn .25s ease; max-width:300px;
}
.toast.out { animation:toastOut .2s ease forwards; }
.toast.t-ok   { border-left:4px solid var(--green); color:var(--green); }
.toast.t-err  { border-left:4px solid var(--red); color:var(--red); }
.toast.t-info { border-left:4px solid var(--primary); color:var(--primary); }
@keyframes toastIn  { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }
@keyframes toastOut { to{opacity:0;transform:translateY(10px)} }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <div class="top-bar-inner">
    <div class="brand">
      <div class="brand-seal">🏥</div>
      <div>
        <div class="brand-name">โรงพยาบาลสันทราย · HRD Division</div>
        <div class="brand-sub">ระบบจัดที่นั่งสัมมนา — Seat Map</div>
      </div>
    </div>
    <div class="top-actions">
      <button class="btn-top" onclick="addTable()">➕ เพิ่มโต๊ะ</button>
      <button class="btn-top" onclick="openAddPerson()">👤 เพิ่มรายชื่อ</button>
      <button class="btn-top" onclick="autoAssign()">⚡ จัดที่นั่งอัตโนมัติ</button>
      <button class="btn-top gold" onclick="exportLayout()">💾 ส่งออก JSON</button>
      <button class="btn-top green" onclick="printMap()">🖨️ พิมพ์ผัง</button>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="main-wrap">

  <!-- SIDEBAR -->
  <div class="sidebar">

    <!-- Stats -->
    <div class="side-card">
      <div class="side-title">สรุปภาพรวม</div>
      <div class="stat-grid">
        <div class="stat-box">
          <div class="stat-num" id="st-total">0</div>
          <div class="stat-lbl">ผู้เข้าร่วมทั้งหมด</div>
        </div>
        <div class="stat-box green">
          <div class="stat-num" id="st-seated">0</div>
          <div class="stat-lbl">มีที่นั่งแล้ว</div>
        </div>
        <div class="stat-box gold">
          <div class="stat-num" id="st-unassigned">0</div>
          <div class="stat-lbl">ยังไม่มีที่นั่ง</div>
        </div>
        <div class="stat-box red">
          <div class="stat-num" id="st-tables">0</div>
          <div class="stat-lbl">โต๊ะทั้งหมด</div>
        </div>
      </div>
    </div>

    <!-- Legend -->
