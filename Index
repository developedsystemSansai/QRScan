<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ระบบสัมมนา – โรงพยาบาลสันทราย</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap');

  :root {
    --bg:        #0d0f1a;
    --surface:   #151929;
    --surface2:  #1e243a;
    --border:    #2a3150;
    --accent:    #4f8ef7;
    --accent2:   #7b5fe8;
    --success:   #00c896;
    --warning:   #f5a623;
    --danger:    #ff5f6d;
    --text:      #e8ecf8;
    --text-dim:  #7a85aa;
    --mono:      'IBM Plex Mono', monospace;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Sarabun', 'Tahoma', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 70% 50% at 20% 10%, rgba(79,142,247,.10) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 90%, rgba(123,95,232,.08) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ══════════════ TAB NAV ══════════════ */
  .tab-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(13,15,26,.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: center;
    gap: 0;
    padding: 0 16px;
  }
  .tab-btn {
    flex: 1; max-width: 200px;
    padding: 14px 12px;
    background: none;
    border: none;
    border-bottom: 2.5px solid transparent;
    color: var(--text-dim);
    font-family: 'Sarabun', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    transition: all .2s;
    margin-bottom: -1px;
  }
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ══════════════ PANELS ══════════════ */
  .panel { display: none; }
  .panel.active { display: block; }

  /* ══════════════ CHECK-IN PANEL ══════════════ */
  #panel-checkin {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 16px 40px;
    gap: 16px;
    max-width: 480px;
    margin: 0 auto;
  }
  #panel-checkin.panel { display: flex; }
  #panel-checkin.panel:not(.active) { display: none; }

  .header {
    width: 100%;
    text-align: center;
    padding: 24px 20px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
  }
  .header-icon {
    font-size: 38px; margin-bottom: 8px; display: block;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }
  .header h1 { font-size: 18px; font-weight: 700; line-height: 1.4; margin-bottom: 3px; }
  .header .subtitle { font-size: 12px; color: var(--text-dim); }

  .status-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 14px; border-radius: 99px;
    font-size: 12px; font-weight: 600; margin-top: 10px; transition: all .3s;
  }
  .status-badge.idle   { background: rgba(122,133,170,.15); color: var(--text-dim); border: 1px solid var(--border); }
  .status-badge.active { background: rgba(0,200,150,.12); color: var(--success); border: 1px solid rgba(0,200,150,.3); }
  .status-badge .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .status-badge.active .dot { animation: pulse 1s ease infinite; }
  @keyframes pulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.5; transform:scale(.7); }
  }

  .camera-wrap {
    width: 100%; background: var(--surface);
    border: 1px solid var(--border); border-radius: 20px;
    overflow: hidden; position: relative; aspect-ratio: 1/1;
    display: flex; align-items: center; justify-content: center;
  }
  #camera-feed { width:100%; height:100%; object-fit:cover; display:none; }
  #scan-canvas { display:none; }

  .viewfinder {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .vf-frame { width: 55%; aspect-ratio: 1/1; position: relative; display: none; }
  .vf-frame.active { display: block; }
  .vf-corner { position: absolute; width: 22px; height: 22px; border-color: var(--accent); border-style: solid; border-width: 0; }
  .vf-corner.tl { top:0;    left:0;  border-top-width:3px;    border-left-width:3px;  border-radius: 4px 0 0 0; }
  .vf-corner.tr { top:0;    right:0; border-top-width:3px;    border-right-width:3px; border-radius: 0 4px 0 0; }
  .vf-corner.bl { bottom:0; left:0;  border-bottom-width:3px; border-left-width:3px;  border-radius: 0 0 0 4px; }
  .vf-corner.br { bottom:0; right:0; border-bottom-width:3px; border-right-width:3px; border-radius: 0 0 4px 0; }
  .vf-scan-line {
    position: absolute; left:5%; right:5%; height:2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: scan 2s ease-in-out infinite; border-radius: 2px; display: none;
  }
  .vf-scan-line.active { display: block; }
  @keyframes scan { 0%{top:8%} 50%{top:88%} 100%{top:8%} }
  .vf-hint { position:absolute; bottom:14px; left:0; right:0; text-align:center; font-size:12px; color:rgba(255,255,255,.5); display:none; }
  .vf-hint.active { display: block; }

  .cam-placeholder {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 10px;
    color: var(--text-dim); text-align: center; padding: 20px;
  }
  .cam-placeholder .ph-icon { font-size: 52px; opacity: .4; }
  .cam-placeholder p { font-size: 13px; line-height: 1.6; }

  .btn-row { width: 100%; display: flex; gap: 12px; }
  .btn {
    flex: 1; padding: 14px 16px; border: none; border-radius: 14px;
    font-family: 'Sarabun', sans-serif; font-size: 14px; font-weight: 600;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    gap: 8px; transition: all .2s; position: relative; overflow: hidden;
  }
  .btn:active { transform: scale(.96); }
  .btn-primary { background: linear-gradient(135deg, var(--accent), #3d6fd4); color:#fff; box-shadow: 0 4px 20px rgba(79,142,247,.35); }
  .btn-primary:hover { box-shadow: 0 6px 28px rgba(79,142,247,.5); }
  .btn-secondary { background: var(--surface2); color: var(--text-dim); border: 1px solid var(--border); }
  .btn-secondary:hover { background: var(--border); color: var(--text); }
  .btn:disabled { opacity:.45; cursor:not-allowed; transform:none; }

  #result-card {
    width: 100%; background: var(--surface); border: 1px solid var(--border);
    border-radius: 20px; padding: 20px; display: none;
    animation: slideUp .35s cubic-bezier(.16,1,.3,1);
    position: relative; overflow: hidden;
  }
  @keyframes slideUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
  #result-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
  #result-card.ok      { border-color: rgba(0,200,150,.4); }
  #result-card.ok::before      { background: linear-gradient(90deg, var(--success), #00a87e); }
  #result-card.warning { border-color: rgba(245,166,35,.4); }
  #result-card.warning::before { background: linear-gradient(90deg, var(--warning), #d4891e); }
  #result-card.error   { border-color: rgba(255,95,109,.4); }
  #result-card.error::before   { background: linear-gradient(90deg, var(--danger), #d43d4d); }

  .result-icon   { font-size:36px; margin-bottom:8px; display:block; text-align:center; }
  .result-msg    { font-size:15px; font-weight:700; text-align:center; margin-bottom:6px; }
  #result-card.ok      .result-msg { color: var(--success); }
  #result-card.warning .result-msg { color: var(--warning); }
  #result-card.error   .result-msg { color: var(--danger); }
  .result-detail { font-size:12px; color:var(--text-dim); text-align:center; line-height:1.6; }
  .result-reg-id {
    margin-top:10px; text-align:center; font-family:var(--mono); font-size:11px;
    color:rgba(122,133,170,.7); background:var(--surface2); padding:6px 12px;
    border-radius:8px; word-break:break-all;
  }
  .countdown-bar { width:100%; height:3px; background:var(--border); border-radius:3px; margin-top:14px; overflow:hidden; display:none; }
  .countdown-bar.active { display:block; }
  .countdown-fill { height:100%; background:var(--accent); border-radius:3px; width:100%; transition:width 3s linear; }

  .stats-row { width:100%; display:flex; gap:10px; }
  .stat-card { flex:1; background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:12px 8px; text-align:center; }
  .stat-num { font-size:26px; font-weight:700; font-family:var(--mono); color:var(--text); }
  .stat-num.green  { color: var(--success); }
  .stat-num.yellow { color: var(--warning); }
  .stat-num.red    { color: var(--danger); }
  .stat-label { font-size:10px; color:var(--text-dim); margin-top:2px; }

  .footer { font-size:11px; color:rgba(122,133,170,.5); text-align:center; line-height:1.6; }

  .spinner { display:none; width:18px; height:18px; border:2.5px solid rgba(255,255,255,.2); border-top-color:#fff; border-radius:50%; animation:spin .7s linear infinite; }
  @keyframes spin { to { transform:rotate(360deg); } }
  .btn.loading .btn-label { display:none; }
  .btn.loading .spinner   { display:block; }

  /* ─── Manual Input ─── */
  .manual-wrap { width: 100%; }
  .manual-divider {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 12px;
  }
  .manual-divider::before, .manual-divider::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
  .manual-divider span { font-size: 11px; color: var(--text-dim); white-space: nowrap; }
  .manual-row { display: flex; gap: 10px; }
  .manual-input {
    flex: 1;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 13px 14px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 13px;
    outline: none;
    transition: border-color .2s;
  }
  .manual-input::placeholder { color: var(--text-dim); opacity: .6; }
  .manual-input:focus { border-color: var(--accent); }
  .btn-manual {
    flex-shrink: 0;
    padding: 0 20px;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--success), #00a87e);
    color: #fff;
    font-family: 'Sarabun', sans-serif;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    transition: all .2s;
    box-shadow: 0 3px 14px rgba(0,200,150,.3);
    min-height: 48px;
  }
  .btn-manual:active { transform: scale(.96); }
  .btn-manual:disabled { opacity: .45; cursor: not-allowed; transform: none; }
  .spinner-sm { display:none; width:16px; height:16px; border:2px solid rgba(255,255,255,.25); border-top-color:#fff; border-radius:50%; animation:spin .7s linear infinite; }
  .btn-manual.loading .btn-manual-label { display: none; }
  .btn-manual.loading .spinner-sm { display: block; }

  /* ══════════════ DASHBOARD PANEL ══════════════ */
  #panel-dashboard {
    position: relative; z-index: 1;
    padding: 20px 16px 40px;
    max-width: 960px;
    margin: 0 auto;
  }

  .dash-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
  }
  .dash-title { font-size: 18px; font-weight: 700; }
  .dash-title span { color: var(--accent); }

  .btn-refresh {
    display: flex; align-items: center; gap: 7px;
    padding: 9px 16px; border-radius: 10px;
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text-dim); font-family: 'Sarabun', sans-serif;
    font-size: 13px; font-weight: 600; cursor: pointer; transition: all .2s;
  }
  .btn-refresh:hover { background: var(--border); color: var(--text); }
  .btn-refresh:disabled { opacity:.5; cursor:not-allowed; }
  .btn-refresh .spin-sm { display:none; width:14px; height:14px; border:2px solid rgba(255,255,255,.2); border-top-color: var(--accent); border-radius:50%; animation:spin .7s linear infinite; }
  .btn-refresh.loading .spin-sm { display:inline-block; }
  .btn-refresh.loading .refresh-icon { display:none; }

  /* KPI Cards */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .kpi-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px 16px;
    position: relative;
    overflow: hidden;
    transition: transform .2s;
  }
  .kpi-card:hover { transform: translateY(-2px); }
  .kpi-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; border-radius:3px 3px 0 0; }
  .kpi-card.blue::before   { background: linear-gradient(90deg, var(--accent), #3d6fd4); }
  .kpi-card.green::before  { background: linear-gradient(90deg, var(--success), #00a87e); }
  .kpi-card.yellow::before { background: linear-gradient(90deg, var(--warning), #d4891e); }
  .kpi-card.purple::before { background: linear-gradient(90deg, var(--accent2), #5a3fc0); }

  .kpi-icon { font-size: 24px; margin-bottom: 8px; display: block; }
  .kpi-value { font-size: 32px; font-weight: 700; font-family: var(--mono); line-height: 1; }
  .kpi-card.blue   .kpi-value { color: var(--accent); }
  .kpi-card.green  .kpi-value { color: var(--success); }
  .kpi-card.yellow .kpi-value { color: var(--warning); }
  .kpi-card.purple .kpi-value { color: var(--accent2); }
  .kpi-label { font-size: 12px; color: var(--text-dim); margin-top: 4px; }

  /* Progress Bar */
  .progress-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px;
    margin-bottom: 20px;
  }
  .progress-section h3 { font-size: 14px; font-weight: 600; color: var(--text-dim); margin-bottom: 14px; text-transform: uppercase; letter-spacing: .05em; }
  .progress-bar-wrap { margin-bottom: 4px; }
  .progress-label-row { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 6px; }
  .progress-bar-bg { width: 100%; height: 10px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
  .progress-bar-fill {
    height: 100%; border-radius: 99px;
    background: linear-gradient(90deg, var(--success), #00a87e);
    transition: width .8s cubic-bezier(.4,0,.2,1);
  }
  .progress-pct { font-size: 28px; font-weight: 700; font-family: var(--mono); color: var(--success); margin-top: 10px; }
  .progress-pct small { font-size: 14px; color: var(--text-dim); font-family: 'Sarabun', sans-serif; font-weight: 400; }

  /* Two-col layout */
  .dash-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 20px;
  }
  @media (max-width: 600px) { .dash-cols { grid-template-columns: 1fr; } }

  /* Recent check-ins list */
  .dash-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 18px;
    overflow: hidden;
  }
  .dash-card h3 { font-size: 13px; font-weight: 600; color: var(--text-dim); margin-bottom: 14px; text-transform: uppercase; letter-spacing: .05em; }

  .checkin-list { display: flex; flex-direction: column; gap: 8px; max-height: 280px; overflow-y: auto; }
  .checkin-list::-webkit-scrollbar { width: 4px; }
  .checkin-list::-webkit-scrollbar-track { background: var(--surface2); border-radius: 4px; }
  .checkin-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .checkin-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 10px; border-radius: 10px; background: var(--surface2);
    animation: slideUp .3s ease;
  }
  .checkin-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--success); flex-shrink: 0; }
  .checkin-name { font-size: 13px; font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .checkin-time { font-size: 10px; color: var(--text-dim); font-family: var(--mono); white-space: nowrap; }
  .no-data { font-size:13px; color:var(--text-dim); text-align:center; padding:20px 0; }

  /* Hourly chart */
  .chart-wrap { width: 100%; }
  .bar-chart { display: flex; align-items: flex-end; gap: 4px; height: 100px; width: 100%; }
  .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .bar-fill {
    width: 100%; border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, var(--accent), #3d6fd4);
    transition: height .7s cubic-bezier(.4,0,.2,1);
    min-height: 2px;
  }
  .bar-lbl { font-size: 9px; color: var(--text-dim); font-family: var(--mono); }

  /* Not-checked-in list */
  .pending-list { display: flex; flex-direction: column; gap: 6px; max-height: 280px; overflow-y: auto; }
  .pending-list::-webkit-scrollbar { width: 4px; }
  .pending-list::-webkit-scrollbar-track { background: var(--surface2); border-radius: 4px; }
  .pending-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
  .pending-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 10px; border-radius: 10px; background: var(--surface2);
  }
  .pending-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--warning); flex-shrink: 0; }
  .pending-name { font-size: 13px; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pending-badge { font-size: 10px; color: var(--text-dim); font-family: var(--mono); background: var(--border); padding: 2px 7px; border-radius: 4px; white-space: nowrap; }

  /* Timestamp */
  .last-update { font-size: 11px; color: rgba(122,133,170,.45); text-align: right; margin-top: -6px; margin-bottom: 14px; }

  /* Skeleton loader */
  .skeleton { background: linear-gradient(90deg, var(--surface2) 25%, var(--border) 50%, var(--surface2) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .skel-kpi { height: 80px; }
  .skel-row { height: 36px; margin-bottom: 6px; }

  /* Error state */
  .dash-error { text-align: center; padding: 40px 20px; }
  .dash-error .err-icon { font-size: 40px; margin-bottom: 12px; }
  .dash-error p { font-size: 14px; color: var(--text-dim); line-height: 1.6; }

  /* ══════════════ CAMERA PERMISSION MODAL ══════════════ */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(13, 15, 26, 0.85);
    backdrop-filter: blur(5px); z-index: 999;
    display: none; align-items: center; justify-content: center;
    padding: 20px; opacity: 0; transition: opacity 0.3s ease;
  }
  .modal-overlay.show { display: flex; opacity: 1; }
  
  .modal-content {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 20px; padding: 28px 24px; max-width: 340px; width: 100%;
    text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    transform: translateY(20px); transition: transform 0.3s ease;
  }
  .modal-overlay.show .modal-content { transform: translateY(0); }
  
  .modal-icon-lg { font-size: 54px; margin-bottom: 12px; }
  .modal-content h3 { font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
  .modal-content p { font-size: 13px; color: var(--text-dim); margin-bottom: 24px; line-height: 1.6; }
  
  .modal-actions { display: flex; gap: 12px; }
  .modal-actions .btn { padding: 12px; font-size: 14px; }
</style>
</head>
<body>

<!-- ═══ TAB NAV ═══ -->
<nav class="tab-nav">
  <button class="tab-btn active" onclick="switchTab('checkin')" id="tab-checkin">
    📷 เช็คอิน QR
  </button>
  <button class="tab-btn" onclick="switchTab('dashboard')" id="tab-dashboard">
    📊 Dashboard
  </button>
</nav>

<!-- ═══════════════════════════════════ -->
<!-- PANEL 1: CHECK-IN                   -->
<!-- ═══════════════════════════════════ -->
<div id="panel-checkin" class="panel active">

  <div class="header">
    <span class="header-icon">🔬</span>
    <h1>เช็คอินสัมมนา</h1>
    <p class="subtitle">แมชชีนเลิร์นนิงและปัญญาประดิษฐ์</p>
    <div class="status-badge idle" id="status-badge">
      <span class="dot"></span>
      <span id="status-text">พร้อมใช้งาน</span>
    </div>
  </div>

  <div class="camera-wrap" id="camera-wrap">
    <video id="camera-feed" playsinline autoplay muted style="display:none; width:100%; height:100%; object-fit:cover;"></video>
