<script>
// ════════════════════════════════════════════
// TAB SWITCHING
// ════════════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + tab).classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
  if (tab === 'dashboard') loadDashboard();
}

// ════════════════════════════════════════════
// CHECK-IN (original logic — unchanged)
// ════════════════════════════════════════════
let stream = null, animFrame = null, scanning = false, processing = false;
let lastCode = "", lastCodeTime = 0;
const COOLDOWN_MS = 4000;
const stats = { total:0, ok:0, dup:0, err:0 };

const videoEl     = document.getElementById("camera-feed");
const canvasEl    = document.getElementById("scan-canvas");
const ctx         = canvasEl.getContext("2d");
const btnOpen     = document.getElementById("btn-open");
const btnClose    = document.getElementById("btn-close");
const placeholder = document.getElementById("cam-placeholder");
const vfFrame     = document.getElementById("vf-frame");
const vfLine      = document.getElementById("vf-line");
const vfHint      = document.getElementById("vf-hint");
const statusBadge = document.getElementById("status-badge");
const statusText  = document.getElementById("status-text");
// ════════════════════════════════════════════
// CAMERA CONTROLS & MODAL
// ════════════════════════════════════════════
// ════════════════════════════════════════════
// SMART CAMERA OPENER (ใช้ง่ายและเสถียรที่สุด)
// ════════════════════════════════════════════

// ════════════════════════════════════════════
// ฟังก์ชันเปิดกล้องแบบ One-Tap (เด้ง Allow ทันที)
// ════════════════════════════════════════════

// ════════════════════════════════════════════
// THE ULTIMATE CAMERA FUNCTION (ฟังก์ชันเปิดกล้องแบบครอบคลุม)
// ════════════════════════════════════════════

async function openCamera() {
  // 1. อัปเดต UI ให้อยู่ในสถานะกำลังโหลด
  setButtonLoading(btnOpen, true);
  setBadge("active", "กำลังเตรียมกล้อง...");

  // 2. เคลียร์การเชื่อมต่อกล้องเดิม (ถ้ามีค้างอยู่) เพื่อป้องกัน Error กล้องถูกใช้งานซ้ำ
  if (stream) {
    stream.getTracks().forEach(track => track.stop());
  }

  let newStream = null;
  let lastError = null;

  // 3. กำหนดแผนการเรียกกล้อง 
  // แผน A: กล้องหลัง (Environment) 
  // แผน B: กล้องพื้นฐาน (สำหรับ PC หรือกรณีแผน A พัง)
  const strategies = [
    { video: { facingMode: { ideal: "environment" } } },
    { video: true }
  ];

  // 4. วนลูปพยายามเปิดกล้องตามแผนที่วางไว้
  for (const constraints of strategies) {
    try {
      // คำสั่งนี้จะเด้งหน้าต่างขออนุญาต (Allow) หากผู้ใช้ยังไม่เคยอนุญาต
      newStream = await navigator.mediaDevices.getUserMedia(constraints);
      if (newStream) break; // ถ้าสำเร็จให้หยุดลูปทันที
    } catch (err) {
      lastError = err;
      console.warn("ข้ามเงื่อนไขกล้อง:", constraints, err.name);
    }
  }

  // 5. ตรวจสอบผลลัพธ์ว่าเปิดกล้องได้หรือไม่
  if (!newStream) {
    setButtonLoading(btnOpen, false);
    setBadge("idle", "พร้อมใช้งาน");
    // เรียกฟังก์ชันจัดการ Error แบบครอบคลุม
    handleComprehensiveCameraError(lastError);
    return;
  }

  // 6. เมื่อเปิดกล้องสำเร็จ นำภาพขึ้นแสดงบนหน้าจอ
  try {
    stream = newStream;
    videoEl.srcObject = stream;
    
    // บังคับตั้งค่าสำหรับ iOS เพื่อไม่ให้จอดำหรือเด้งเต็มจอ
    videoEl.setAttribute("playsinline", "true");
    videoEl.setAttribute("autoplay", "true");
    videoEl.setAttribute("muted", "true");

    await videoEl.play();

    // แสดงผลหน้าจอ UI กล้อง
    videoEl.style.display = "block";
    if (placeholder) placeholder.style.display = "none";
    if (vfFrame) vfFrame.classList.add("active");
    if (vfLine) vfLine.classList.add("active");
    if (vfHint) vfHint.classList.add("active");

    // ปรับสถานะปุ่ม
    setButtonLoading(btnOpen, false);
    btnOpen.disabled = true;
    btnClose.disabled = false;
    setBadge("active", "กำลังสแกน...");

    // เริ่มต้นลูปการสแกน QR Code
    scanning = true;
    scanLoop();

  } catch (playError) {
    console.error("Video Playback Error:", playError);
    setButtonLoading(btnOpen, false);
    setBadge("idle", "พร้อมใช้งาน");
    alert("❌ เกิดข้อผิดพลาดในการแสดงภาพจากกล้อง: " + playError.message);
  }
}

// ════════════════════════════════════════════
// ฟังก์ชันวิเคราะห์และแจ้งเตือน Error แบบเข้าใจง่าย
// ════════════════════════════════════════════
function handleComprehensiveCameraError(err) {
  // 1. ดักจับการเปิดผ่าน In-App Browser (LINE, Facebook, IG)
  const ua = navigator.userAgent || navigator.vendor || window.opera;
  const isInApp = (ua.indexOf("FBAN") > -1) || (ua.indexOf("FBAV") > -1) || (ua.indexOf("Line") > -1);

  if (isInApp) {
    alert("⚠️ คุณกำลังเปิดเว็บผ่านแอป (เช่น LINE/Facebook)\nซึ่งระบบแอปมักจะบล็อกกล้องไว้\n\n👉 กรุณากดเมนู (จุด 3 จุด) แล้วเลือก\n'เปิดในเบราว์เซอร์อื่น' หรือ 'Open in Safari/Chrome' ครับ");
    return;
  }

  // 2. แยกแยะ Error ปกติ
  let msg = "❌ ไม่สามารถใช้งานกล้องได้\n";
  
  if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
    msg = "⚠️ คุณยังไม่ได้อนุญาตให้ใช้กล้อง (หรือเคยบล็อกไว้)\n\nวิธีแก้:\n1. กดไอคอน 🎚️ หรือ 'aA' ตรงแถบ URL\n2. ไปที่ 'การตั้งค่าเว็บไซต์ (Site Settings)'\n3. ตั้งค่ากล้องเป็น 'อนุญาต (Allow)'\n4. รีเฟรชหน้าเว็บ 1 ครั้ง";
  } 
  else if (err.name === 'NotFoundError' || err.name === 'DevicesNotFoundError') {
    msg = "❌ ไม่พบอุปกรณ์กล้องในเครื่องของคุณ หรือระบบมองไม่เห็นกล้องครับ";
  } 
  else if (err.name === 'NotReadableError' || err.name === 'TrackStartError') {
    msg = "❌ กล้องกำลังถูกใช้งานโดยแอปอื่นอยู่!\n(เช่น แอปถ่ายรูป หรือ วิดีโอคอล)\n\n👉 กรุณาปิดแอปเหล่านั้นออกจากพื้นหลัง (Recent apps) แล้วลองใหม่ครับ";
  } 
  else {
    msg += "\nข้อผิดพลาดทางเทคนิค: " + (err.message || err.name);
  }
  
  alert(msg);
}

// ฟังก์ชันเสริมสำหรับแจ้งเตือน Error ให้เข้าใจง่าย
function handleCameraError(err) {
  let msg = "❌ ไม่สามารถเข้าถึงกล้องได้";
  if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
    msg = "⚠️ กรุณาอนุญาต (Allow) การเข้าถึงกล้อง\nโดยกดที่ไอคอนตั้งค่าข้างแถบ URL ครับ";
  } else if (err.name === 'NotFoundError' || err.name === 'DevicesNotFoundError') {
    msg = "❌ ไม่พบอุปกรณ์กล้องในเครื่องของคุณ";
  }
  alert(msg);
}

// 2. ปิด Pop-up ถ้ายกเลิก
function closeCameraModal() {
  document.getElementById('camera-modal').classList.remove('show');
}

// 3. เมื่อผู้ใช้กด "อนุญาต" บน Pop-up
async function acceptCameraPermission() {
  // ปิด Pop-up
  closeCameraModal();
  
  // แสดงสถานะโหลดที่ปุ่มหลัก
  setButtonLoading(btnOpen, true);
  setBadge("active", "กำลังขอสิทธิ์กล้อง...");

  try {
    // บรรทัดนี้จะทำให้เบราว์เซอร์เด้งขอสิทธิ์ (ถ้ายังไม่เคยอนุญาต) ทันทีเพราะเกิดจากการกดปุ่มของผู้ใช้
    stream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode:"environment", width:{ideal:1280}, height:{ideal:1280} }
    });

    videoEl.srcObject = stream;
    await videoEl.play();
    videoEl.style.display = "block";
    placeholder.style.display = "none";
    vfFrame.classList.add("active");
    vfLine.classList.add("active");
    vfHint.classList.add("active");
    
    setButtonLoading(btnOpen, false);
    btnOpen.disabled = true;
    btnClose.disabled = false;
    setBadge("active", "กำลังสแกน...");
    scanning = true;
    scanLoop();
    
  } catch(err) {
    setButtonLoading(btnOpen, false);
    showResult("error","❌","ไม่สามารถเปิดกล้องได้","ผู้ใช้อาจปฏิเสธการเข้าถึง หรือไม่มีกล้อง","");
    setBadge("idle","พร้อมใช้งาน");
  }
}

function closeCamera() {
  scanning = false;
  if (animFrame) cancelAnimationFrame(animFrame);
  if (stream) stream.getTracks().forEach(t => t.stop());
  stream = null; animFrame = null;
  videoEl.style.display = "none"; videoEl.srcObject = null;
  placeholder.style.display = "flex";
  vfFrame.classList.remove("active");
  vfLine.classList.remove("active");
  vfHint.classList.remove("active");
  btnOpen.disabled = false; btnClose.disabled = true;
  setBadge("idle","พร้อมใช้งาน");
}

function scanLoop() {
  if (!scanning) return;
  if (videoEl.readyState === videoEl.HAVE_ENOUGH_DATA) {
    canvasEl.width = videoEl.videoWidth; canvasEl.height = videoEl.videoHeight;
    ctx.drawImage(videoEl, 0, 0, canvasEl.width, canvasEl.height);
    const imageData = ctx.getImageData(0, 0, canvasEl.width, canvasEl.height);
    const code = jsQR(imageData.data, imageData.width, imageData.height, { inversionAttempts:"dontInvert" });
    if (code) {
      const now = Date.now(), data = code.data.trim();
      if (!processing && (data !== lastCode || now - lastCodeTime > COOLDOWN_MS)) {
        lastCode = data; lastCodeTime = now;
        handleScan(data);
      }
    }
  }
  animFrame = requestAnimationFrame(scanLoop);
}

function handleScan(regId) {
  if (processing) return;
  processing = true;
  setBadge("active","กำลังตรวจสอบ...");
  if (navigator.vibrate) navigator.vibrate(80);
  stats.total++; updateStats();
  google.script.run
    .withSuccessHandler(onCheckInResult)
    .withFailureHandler(onCheckInError)
    .processCheckIn(regId);
  showResultLoading(regId);
}

function onCheckInResult(res) {
  if (res.status === "checkin_ok") {
    stats.ok++;
    showResult("ok","✅",res.message, res.time ? "เวลาเช็คอิน: "+res.time : "", lastCode);
  } else if (res.status === "already_checkin") {
    stats.dup++;
    showResult("warning","⚠️",res.message,"กรุณาติดต่อเจ้าหน้าที่",lastCode);
  } else {
    stats.err++;
    showResult("error","❌",res.message,"ตรวจสอบรหัสลงทะเบียนอีกครั้ง",lastCode);
  }
  updateStats(); setBadge("active","กำลังสแกน..."); scheduleReset();
}

function onCheckInError(err) {
  stats.err++;
  showResult("error","❌","เกิดข้อผิดพลาด","ไม่สามารถเชื่อมต่อฐานข้อมูลได้",lastCode);
  updateStats(); setBadge("active","กำลังสแกน..."); scheduleReset();
}

function showResult(type, icon, msg, detail, regId) {
  const card = document.getElementById("result-card");
  card.className = type; card.style.display = "block";
  document.getElementById("result-icon").textContent   = icon;
  document.getElementById("result-msg").textContent    = msg;
  document.getElementById("result-detail").textContent = detail;
  document.getElementById("result-reg-id").textContent = regId ? "🔑 "+regId : "";
  document.getElementById("result-reg-id").style.display = regId ? "block" : "none";
  const bar = document.getElementById("countdown-bar");
  const fill = document.getElementById("countdown-fill");
  bar.classList.add("active"); fill.style.width = "100%";
  requestAnimationFrame(() => requestAnimationFrame(() => { fill.style.width = "0%"; }));
}

function showResultLoading(regId) {
  const card = document.getElementById("result-card");
  card.className = "ok"; card.style.display = "block";
  document.getElementById("result-icon").textContent   = "⏳";
  document.getElementById("result-msg").textContent    = "กำลังตรวจสอบข้อมูล...";
  document.getElementById("result-detail").textContent = "โปรดรอสักครู่";
  document.getElementById("result-reg-id").textContent = "🔑 "+regId;
  document.getElementById("result-reg-id").style.display = "block";
  document.getElementById("countdown-bar").classList.remove("active");
}

function scheduleReset() {
  setTimeout(() => {
    processing = false;
    document.getElementById("result-card").style.display = "none";
    document.getElementById("countdown-bar").classList.remove("active");
  }, 3200);
}

function updateStats() {
  document.getElementById("stat-total").textContent = stats.total;
  document.getElementById("stat-ok").textContent    = stats.ok;
  document.getElementById("stat-dup").textContent   = stats.dup;
  document.getElementById("stat-err").textContent   = stats.err;
}

function setBadge(type, text) {
  statusBadge.className = "status-badge "+type;
  statusText.textContent = text;
}

function setButtonLoading(btn, loading) {
  if (loading) btn.classList.add("loading");
  else         btn.classList.remove("loading");
  btn.disabled = loading;
}

// ─── Manual Check-in ───
function manualCheckin() {
  const input  = document.getElementById("manual-input");
  const btn    = document.getElementById("btn-manual");
  const regId  = (input.value || "").trim().toUpperCase();

  if (!regId) {
    input.focus();
    input.style.borderColor = "var(--danger)";
    setTimeout(() => { input.style.borderColor = ""; }, 1500);
    return;
  }

  btn.classList.add("loading");
  btn.disabled = true;
  input.disabled = true;

  stats.total++;
  updateStats();
  lastCode = regId;

  google.script.run
    .withSuccessHandler(function(res) {
      btn.classList.remove("loading");
      btn.disabled = false;
      input.disabled = false;
      input.value = "";
      input.focus();
      onCheckInResult(res);
    })
    .withFailureHandler(function(err) {
      btn.classList.remove("loading");
      btn.disabled = false;
      input.disabled = false;
      onCheckInError(err);
    })
    .processCheckIn(regId);
}

// ════════════════════════════════════════════
// DASHBOARD
// ════════════════════════════════════════════
let dashLoaded = false;

function loadDashboard() {
  const btn = document.getElementById("btn-refresh");
  btn.classList.add("loading");
  btn.disabled = true;

  google.script.run
    .withSuccessHandler(renderDashboard)
    .withFailureHandler(renderDashboardError)
    .getDashboardData();
}

function renderDashboard(d) {
  const btn = document.getElementById("btn-refresh");
  btn.classList.remove("loading");
  btn.disabled = false;

  // Timestamp
  document.getElementById("last-update").textContent = "อัปเดตล่าสุด: " + d.lastUpdate;

  // KPI
  const pct = d.total > 0 ? Math.round((d.checkedIn / d.total) * 100) : 0;
  document.getElementById("kpi-grid").innerHTML = `
    <div class="kpi-card blue">
      <span class="kpi-icon">👥</span>
      <div class="kpi-value">${d.total}</div>
      <div class="kpi-label">ลงทะเบียนทั้งหมด</div>
    </div>
    <div class="kpi-card green">
      <span class="kpi-icon">✅</span>
      <div class="kpi-value">${d.checkedIn}</div>
      <div class="kpi-label">เช็คอินแล้ว</div>
    </div>
    <div class="kpi-card yellow">
      <span class="kpi-icon">⏳</span>
      <div class="kpi-value">${d.total - d.checkedIn}</div>
      <div class="kpi-label">ยังไม่ได้เช็คอิน</div>
    </div>
    <div class="kpi-card purple">
      <span class="kpi-icon">📧</span>
      <div class="kpi-value">${d.emailSent}</div>
      <div class="kpi-label">ส่งอีเมลแล้ว</div>
    </div>
  `;

  // Progress bar
  document.getElementById("prog-label").textContent = d.checkedIn + " / " + d.total;
  document.getElementById("prog-pct").innerHTML = pct + '% <small>เช็คอิน</small>';
  setTimeout(() => {
    document.getElementById("prog-fill").style.width = pct + "%";
  }, 100);

  // Recent check-ins
  const list = document.getElementById("checkin-list");
  if (d.recentCheckins && d.recentCheckins.length > 0) {
    list.innerHTML = d.recentCheckins.map(r =>
      `<div class="checkin-item">
        <div class="checkin-dot"></div>
        <div class="checkin-name">${escHtml(r.name)}</div>
        <div class="checkin-time">${escHtml(r.time)}</div>
      </div>`
    ).join("");
  } else {
    list.innerHTML = '<div class="no-data">ยังไม่มีการเช็คอิน</div>';
  }

  // Hourly chart
  const chart = document.getElementById("hourly-chart");
  if (d.hourly && d.hourly.length > 0) {
    const maxVal = Math.max(...d.hourly.map(h => h.count), 1);
    chart.innerHTML = d.hourly.map(h => {
      const pctH = Math.round((h.count / maxVal) * 100);
      return `<div class="bar-group">
        <div class="bar-fill" style="height:${pctH}%"></div>
        <div class="bar-lbl">${escHtml(h.hour)}</div>
      </div>`;
    }).join("");
  } else {
    chart.innerHTML = '<div class="no-data" style="width:100%;font-size:12px">ยังไม่มีข้อมูล</div>';
  }

  // Pending list
  const pending = document.getElementById("pending-list");
  document.getElementById("pending-count").textContent = d.pending ? "("+d.pending.length+")" : "";
  if (d.pending && d.pending.length > 0) {
    pending.innerHTML = d.pending.map(p =>
      `<div class="pending-item">
        <div class="pending-dot"></div>
        <div class="pending-name">${escHtml(p.name)}</div>
        <div class="pending-badge">${escHtml(p.regId)}</div>
      </div>`
    ).join("");
  } else {
    pending.innerHTML = '<div class="no-data">🎉 ทุกคนเช็คอินครบแล้ว!</div>';
  }

  dashLoaded = true;
}

function renderDashboardError(err) {
  const btn = document.getElementById("btn-refresh");
  btn.classList.remove("loading");
  btn.disabled = false;
  document.getElementById("kpi-grid").innerHTML =
    `<div class="dash-error" style="grid-column:1/-1">
      <div class="err-icon">⚠️</div>
      <p>ไม่สามารถโหลดข้อมูลได้<br><small>${err.message || "กรุณาลองใหม่อีกครั้ง"}</small></p>
    </div>`;
}

function escHtml(s) {
  return String(s || "")
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;");
}
